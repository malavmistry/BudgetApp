@page
@model BudgetApp.Pages.ReportModel
@using BudgetApp.Enums
@{
    ViewData["Title"] = "Report";
}

<div class="row g-4">
    <!-- Filter Panel -->
    <div class="col-lg-3">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filters</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Period</label>
                        <select class="form-select" asp-for="Filter.Period" id="periodSelect"
                                onchange="toggleCustomRange(this.value)">
                            <option value="1">This Month</option>
                            <option value="2">Year to Date</option>
                            <option value="3">Previous Year</option>
                            <option value="4">Custom Range</option>
                        </select>
                    </div>

                    <div id="customRangeSection" class="d-none mb-3">
                        <label class="form-label fw-semibold small">From</label>
                        <input type="date" class="form-control form-control-sm mb-2"
                               asp-for="Filter.CustomStart" />
                        <label class="form-label fw-semibold small">To</label>
                        <input type="date" class="form-control form-control-sm"
                               asp-for="Filter.CustomEnd" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Budget</label>
                        <select class="form-select form-select-sm" asp-for="Filter.BudgetId">
                            <option value="">All Budgets</option>
                            @foreach (var b in Model.Budgets)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <select class="form-select form-select-sm" asp-for="Filter.CategoryId">
                            <option value="">All Categories</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Type</label>
                        <select class="form-select form-select-sm" asp-for="Filter.Type">
                            <option value="">All Types</option>
                            <option value="2">Earnings</option>
                            <option value="1">Expense</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>Generate Report
                        </button>
                        <button type="submit" asp-page-handler="Export" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Results -->
    <div class="col-lg-9">
        @if (Model.Result is not null)
        {
            <div class="mb-3 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold text-primary mb-0">
                    <i class="bi bi-bar-chart me-2"></i>@Model.Result.PeriodLabel
                </h5>
                <div class="d-flex gap-3">
                    <span class="badge bg-success-subtle text-success fs-6 fw-semibold">
                        Earnings: $@Model.Result.TotalEarnings.ToString("N2")
                    </span>
                    <span class="badge bg-danger-subtle text-danger fs-6 fw-semibold">
                        Expense: $@Model.Result.TotalExpense.ToString("N2")
                    </span>
                    <span class="badge @(Model.Result.Net >= 0 ? "bg-primary-subtle text-primary" : "bg-warning-subtle text-warning-emphasis") fs-6 fw-semibold">
                        Net: $@Model.Result.Net.ToString("N2")
                    </span>
                </div>
            </div>

            <!-- Pie Charts -->
            @if (Model.Result.ExpensePie.Any() || Model.Result.EarningsPie.Any())
            {
                <div class="row g-3 mb-4">
                    @if (Model.Result.ExpensePie.Any())
                    {
                        <div class="col-md-6">
                            <div class="card shadow-sm">
                                <div class="card-header bg-danger-subtle">
                                    <h6 class="mb-0 text-danger fw-semibold">
                                        <i class="bi bi-pie-chart me-1"></i>Expense by @Model.Result.PieGroupLabel
                                    </h6>
                                </div>
                                <div class="card-body d-flex justify-content-center">
                                    <div style="max-width: 320px; width: 100%;">
                                        <canvas id="expensePieChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (Model.Result.EarningsPie.Any())
                    {
                        <div class="col-md-6">
                            <div class="card shadow-sm">
                                <div class="card-header bg-success-subtle">
                                    <h6 class="mb-0 text-success fw-semibold">
                                        <i class="bi bi-pie-chart me-1"></i>Earnings by @Model.Result.PieGroupLabel
                                    </h6>
                                </div>
                                <div class="card-body d-flex justify-content-center">
                                    <div style="max-width: 320px; width: 100%;">
                                        <canvas id="earningsPieChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Data Table -->
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Name</th>
                                    <th>Category</th>
                                    <th>Type</th>
                                    <th class="text-end">Amount</th>
                                    <th>Budget</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Result.Rows)
                                {
                                    <tr>
                                        <td class="text-nowrap small">@row.Date</td>
                                        <td class="small">@row.ItemName</td>
                                        <td class="small">@row.Category</td>
                                        <td>
                                            <span class="badge @(row.Type == "Expense" ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") small">
                                                @row.Type
                                            </span>
                                        </td>
                                        <td class="text-end fw-semibold small
                                            @(row.Type == "Expense" ? "text-danger" : "text-success")">
                                            $@row.Amount.ToString("N2")
                                        </td>
                                        <td class="small text-muted">@row.Budget</td>
                                        <td class="small text-muted">@row.Note</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (!Model.Result.Rows.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 opacity-25"></i>
                            <p class="mt-2">No data for the selected filters</p>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-bar-chart fs-1 opacity-25 d-block"></i>
                <p class="mt-3">Select filters and click Generate Report to view results</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleCustomRange(val) {
            document.getElementById('customRangeSection').classList.toggle('d-none', val !== '4');
        }
        toggleCustomRange(document.getElementById('periodSelect').value);

        const expensePie = @Html.Raw(Model.ExpensePieJson);
        const earningsPie = @Html.Raw(Model.EarningsPieJson);
        HomeModule.initPieChart('expensePieChart', expensePie);
        HomeModule.initPieChart('earningsPieChart', earningsPie);
    </script>
}
