@page
@model BudgetApp.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Budget App – Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="card shadow-lg p-4" style="min-width: 380px; max-width: 420px; width: 100%;">
            <div class="text-center mb-4">
                <i class="bi bi-wallet2 text-primary" style="font-size: 3rem;"></i>
                <h3 class="mt-2 fw-bold text-primary">Finora</h3>
                <p class="text-muted small">Track your finances simply</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger small">@Model.ErrorMessage</div>
            }

            <!-- Login Form -->
            <form method="post" id="loginForm">
                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" class="form-control" id="username" name="Input.Username"
                               value="@Model.Input.Username" maxlength="25"
                               autocomplete="off" placeholder="Enter username" required />
                    </div>
                </div>
                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </button>
                </div>
            </form>

            <hr />

            <div class="d-flex gap-2 justify-content-center">
                <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('forgotSection').classList.toggle('d-none')">
                    <i class="bi bi-question-circle me-1"></i>Forgot Username
                </button>
                <button class="btn btn-outline-primary btn-sm" onclick="document.getElementById('createSection').classList.toggle('d-none')">
                    <i class="bi bi-person-plus me-1"></i>Create User
                </button>
            </div>

            <!-- Forgot Username Section -->
            <div id="forgotSection" class="d-none mt-3">
                <div class="card bg-light border-0 p-3">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-people me-1"></i>Registered Users</h6>
                    @if (Model.AllUsers.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var user in Model.AllUsers)
                            {
                                <li class="list-group-item bg-transparent py-1 small">
                                    <button class="btn btn-link p-0 text-start"
                                            onclick="document.getElementById('username').value = '@Html.Raw(user.Username)'; document.getElementById('forgotSection').classList.add('d-none');">
                                        <i class="bi bi-person me-1"></i>@user.Username
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No users registered yet.</p>
                    }
                </div>
            </div>

            <!-- Create User Section -->
            <div id="createSection" class="d-none mt-3">
                <div class="card bg-light border-0 p-3">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-person-plus me-1"></i>Create New User</h6>
                    <form method="post" asp-page-handler="CreateUser">
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" name="newUsername"
                                   maxlength="25" placeholder="New username" required />
                            <button class="btn btn-primary btn-sm" type="submit">Create</button>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.CreateMessage))
                        {
                            <small class="text-success mt-1 d-block">@Model.CreateMessage</small>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
